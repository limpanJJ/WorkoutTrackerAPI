@baseUrl = https://localhost:7103

### =====================
### AUTH
### =====================

### Register
POST {{baseUrl}}/api/auth/register
Content-Type: application/json

{
  "email": "jane.doe@example.com",
  "password": "JaneDoe123!",
  "username": "jane.doe"
}

### Login
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "john.doe@example.com",
  "password": "JohnDoe123!"
}

### =====================
### EXERCISE CATEGORIES
### =====================

### Get all categories
GET {{baseUrl}}/api/exercise-categories

### Get category by ID
GET {{baseUrl}}/api/exercise-categories/1

### Create category (Admin)
POST {{baseUrl}}/api/exercise-categories
Content-Type: application/json

{
  "name": "Plyometrics"
}

### Update category (Admin)
PUT {{baseUrl}}/api/exercise-categories/1
Content-Type: application/json

{
  "name": "Strength Training"
}

### Delete category (Admin)
DELETE {{baseUrl}}/api/exercise-categories/1

### =====================
### EXERCISES
### =====================

### Get all exercises
GET {{baseUrl}}/api/exercises

### Get exercise by ID 
GET {{baseUrl}}/api/exercises/82CE0C6E-DB57-48C0-BB73-C853BD8ECA05

### Create exercise
POST {{baseUrl}}/api/exercises
Content-Type: application/json

{
  "name": "Bench Press",
  "categoryId": 1,
  "muscleGroupId": 3
}

### Create exercise (cardio, no muscle group)
POST {{baseUrl}}/api/exercises
Content-Type: application/json

{
  "name": "Jump Rope",
  "categoryId": 2,
  "muscleGroupId": null
}

### Update exercise (replace with real GUID)
PUT {{baseUrl}}/api/exercises/00000000-0000-0000-0000-000000000000
Content-Type: application/json

{
  "name": "Incline Bench Press",
  "categoryId": 1,
  "muscleGroupId": 3
}

### Delete exercise (replace with real GUID)
DELETE {{baseUrl}}/api/exercises/00000000-0000-0000-0000-000000000000


### =====================
### WORKOUT SESSIONS
### =====================

### Get all workout sessions
GET {{baseUrl}}/api/workout-session

### Get workout session by ID (replace with real GUID)
GET {{baseUrl}}/api/workout-session/00000000-0000-0000-0000-000000000000

### Create workout session
POST {{baseUrl}}/api/workout-session
Content-Type: application/json

{
  "name": "Morning Push Session",
  "notes": "Focus on chest and triceps"
}

### Update workout session (replace with real GUID)
PUT {{baseUrl}}/api/workout-session/00000000-0000-0000-0000-000000000000
Content-Type: application/json

{
  "name": "Updated Session Name",
  "notes": "Changed focus to full body"
}

### Delete workout session (replace with real GUID)
DELETE {{baseUrl}}/api/workout-session/00000000-0000-0000-0000-000000000000

### =====================
### WORKOUT EXERCISES
### =====================

### Add exercise to workout session (replace session GUID)
POST {{baseUrl}}/api/workout-session/00000000-0000-0000-0000-000000000000/exercises
Content-Type: application/json

{
  "exerciseId": "00000000-0000-0000-0000-000000000000",
  "order": 1
}

### Update workout exercise (replace GUIDs)
PUT {{baseUrl}}/api/workout-session/00000000-0000-0000-0000-000000000000/exercises/00000000-0000-0000-0000-000000000000
Content-Type: application/json

{
  "order": 2
}

### Delete workout exercise (replace GUIDs)
DELETE {{baseUrl}}/api/workout-session/00000000-0000-0000-0000-000000000000/exercises/00000000-0000-0000-0000-000000000000

### =====================
### WORKOUT EXERCISE SETS
### =====================

### Add set to workout exercise (replace GUIDs)
POST {{baseUrl}}/api/workout-session/00000000-0000-0000-0000-000000000000/exercises/00000000-0000-0000-0000-000000000000/sets
Content-Type: application/json

{
  "setNumber": 1,
  "reps": 10,
  "weight": 80
}

### Update exercise set (replace GUIDs)
PUT {{baseUrl}}/api/workout-session/00000000-0000-0000-0000-000000000000/exercises/00000000-0000-0000-0000-000000000000/sets/00000000-0000-0000-0000-000000000000
Content-Type: application/json

{
  "setNumber": 1,
  "reps": 12,
  "weight": 85
}

### Delete exercise set (replace GUIDs)
DELETE {{baseUrl}}/api/workout-session/00000000-0000-0000-0000-000000000000/exercises/00000000-0000-0000-0000-000000000000/sets/00000000-0000-0000-0000-000000000000